# ── SUPABASE ──────────────────────────────────────────────────
# Your project URL (e.g. https://xxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# The specific anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role key (do not expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ── APP ───────────────────────────────────────────────────────
# The domain where your app is hosted (e.g. https://my-nexdesk-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI ENGINE (GROQ) ──────────────────────────────────────────
# Get your API key from console.groq.com
GROQ_API_KEY=

# ── EMAIL (RESEND) ────────────────────────────────────────────
# Get your API key from resend.com for autonomous email actions
RESEND_API_KEY=
